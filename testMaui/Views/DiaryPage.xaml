<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.DiaryPage"
             Title="Дневник питания">
    <ContentPage.BindingContext>
        <viewmodels:DiaryViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Выбор даты -->
        <DatePicker Date="{Binding SelectedDate}" Grid.Row="0" Margin="10" />

        <!-- Сводка за день -->
        <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5">
            <Label Text="Итоги дня:" FontAttributes="Bold"/>
            <Label Text="{Binding TotalCalories, StringFormat='Калории: {0:F0} / {1:F0} ккал'}" />
            <Label Text="{Binding TotalProteins, StringFormat='Белки: {0:F1} / {1:F1} г'}" />
            <Label Text="{Binding TotalFats, StringFormat='Жиры: {0:F1} / {1:F1} г'}" />
            <Label Text="{Binding TotalCarbs, StringFormat='Углеводы: {0:F1} / {1:F1} г'}" />
        </VerticalStackLayout>

        <!-- Список приёмов пищи -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Meals}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10" Spacing="5">
                        <Label Text="{Binding Type}" FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding Items}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="{Binding Product.Name}" />
                                        <Label Text="{Binding QuantityGrams, StringFormat='{0} г'}" />
                                        <Label Text="{Binding Calories, StringFormat='{0:F0} ккал'}" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Button Text="Удалить приём" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:DiaryViewModel}}, Path=DeleteMealCommand}" CommandParameter="{Binding .}" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Добавление записи -->
        <VerticalStackLayout Grid.Row="3" Padding="10" Spacing="5">
            <Picker Title="Тип приёма" SelectedItem="{Binding SelectedMealType}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Завтрак</x:String>
                        <x:String>Обед</x:String>
                        <x:String>Ужин</x:String>
                        <x:String>Перекус</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Picker Title="Продукт" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProductForAdd}">
                <Picker.ItemDisplayBinding>
                    <Binding Path="Name" />
                </Picker.ItemDisplayBinding>
            </Picker>
            <Entry Placeholder="Масса (г)" Text="{Binding QuantityGrams}" Keyboard="Numeric" />
            <Button Text="Добавить" Command="{Binding AddMealItemCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>