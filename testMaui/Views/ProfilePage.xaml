<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.ProfilePage"
             Title="Профиль">
    <ContentPage.BindingContext>
        <viewmodels:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Entry Placeholder="Имя" Text="{Binding UserName}" />
            <Entry Placeholder="Возраст" Text="{Binding Age}" Keyboard="Numeric" />
            <Picker Title="Пол" SelectedItem="{Binding Gender}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Male</x:String>
                        <x:String>Female</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Entry Placeholder="Вес (кг)" Text="{Binding Weight}" Keyboard="Numeric" />
            <Entry Placeholder="Рост (см)" Text="{Binding Height}" Keyboard="Numeric" />
            <Picker Title="Активность" SelectedItem="{Binding ActivityLevel}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Low</x:String>
                        <x:String>Moderate</x:String>
                        <x:String>High</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <!-- Новый Picker для цели -->
            <Picker Title="Цель" SelectedItem="{Binding Goal}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Lose</x:String>
                        <x:String>Maintain</x:String>
                        <x:String>Gain</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Entry Placeholder="Пароль" Text="{Binding Password}" IsPassword="True" />
            <Button Text="Сохранить профиль" Command="{Binding SaveProfileCommand}" />
            <Button Text="Выйти" Command="{Binding LogoutCommand}" BackgroundColor="Gray" Margin="0,20,0,0" />
            <Label Text="Рассчитанные нормы:" FontAttributes="Bold" Margin="0,20,0,0"/>
            <Label Text="{Binding DailyCalorieNorm, StringFormat='Калории: {0:F0} ккал'}" />
            <Label Text="{Binding DailyProteinNorm, StringFormat='Белки: {0:F1} г'}" />
            <Label Text="{Binding DailyFatNorm, StringFormat='Жиры: {0:F1} г'}" />
            <Label Text="{Binding DailyCarbNorm, StringFormat='Углеводы: {0:F1} г'}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>