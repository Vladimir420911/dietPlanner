<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.ProductsPage"
             Title="Продукты">
    <ContentPage.BindingContext>
        <viewmodels:ProductsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Список продуктов -->
        <CollectionView x:Name="ProductsCollection" Grid.Row="1"
                        ItemsSource="{Binding Products}"
                        SelectedItem="{Binding SelectedProduct}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10" Spacing="5">
                        <Label Text="{Binding Name}" FontAttributes="Bold"/>
                        <Label Text="{Binding Calories, StringFormat='{0} ккал'}" />
                        <Label Text="{Binding Proteins, StringFormat='Б: {0:F1}г / Ж: {1:F1}г / У: {2:F1}г'}" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Панель добавления/редактирования -->
        <VerticalStackLayout Grid.Row="2" Padding="10" Spacing="5">
            <Entry Placeholder="Название" Text="{Binding NewProductName}" />
            <Entry Placeholder="Калории (ккал)" Text="{Binding NewProductCalories}" Keyboard="Numeric" />
            <Entry Placeholder="Белки (г)" Text="{Binding NewProductProteins}" Keyboard="Numeric" />
            <Entry Placeholder="Жиры (г)" Text="{Binding NewProductFats}" Keyboard="Numeric" />
            <Entry Placeholder="Углеводы (г)" Text="{Binding NewProductCarbs}" Keyboard="Numeric" />
            <Button Text="Добавить продукт" Command="{Binding AddProductCommand}" />
            <Button Text="Обновить выбранный" Command="{Binding UpdateProductCommand}" />
            <Button Text="Удалить выбранный" Command="{Binding DeleteProductCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>