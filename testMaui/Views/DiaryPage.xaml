<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             xmlns:local="clr-namespace:testMaui"
             x:Class="testMaui.Views.DiaryPage"
             Title="Дневник питания"
             BackgroundColor="#F5F5F5">
    <ContentPage.BindingContext>
        <viewmodels:DiaryViewModel />
    </ContentPage.BindingContext>
    <ContentPage.Resources>
        <local:SelectedTypeToColorConverter x:Key="SelectedTypeToColor" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="10" Padding="15">
        <!-- Дата -->
        <DatePicker Date="{Binding SelectedDate}"
                    Grid.Row="0"
                    BackgroundColor="White"
                    Margin="0,5"
                    HorizontalOptions="FillAndExpand" />

        <!-- Вкладки типов приёмов и кнопка + -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <HorizontalStackLayout HorizontalOptions="Start" Spacing="5">
                <Button Text="Завтрак"
                        Command="{Binding SelectMealTypeCommand}"
                        CommandParameter="Завтрак"
                        BackgroundColor="{Binding SelectedMealType, Converter={StaticResource SelectedTypeToColor}, ConverterParameter=Завтрак}"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="15,8" />
                <Button Text="Обед"
                        Command="{Binding SelectMealTypeCommand}"
                        CommandParameter="Обед"
                        BackgroundColor="{Binding SelectedMealType, Converter={StaticResource SelectedTypeToColor}, ConverterParameter=Обед}"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="15,8" />
                <Button Text="Ужин"
                        Command="{Binding SelectMealTypeCommand}"
                        CommandParameter="Ужин"
                        BackgroundColor="{Binding SelectedMealType, Converter={StaticResource SelectedTypeToColor}, ConverterParameter=Ужин}"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="15,8" />
                <Button Text="Перекус"
                        Command="{Binding SelectMealTypeCommand}"
                        CommandParameter="Перекус"
                        BackgroundColor="{Binding SelectedMealType, Converter={StaticResource SelectedTypeToColor}, ConverterParameter=Перекус}"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="15,8" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Сводка с прогресс-барами -->
        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Label Text="Прогресс дня" FontAttributes="Bold" FontSize="16" />
            <Frame Padding="10" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <!-- Калории -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Калории" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding TotalCalories, StringFormat='{0:F0} / {1:F0} ккал'}" FontSize="14" />
                    </Grid>
                    <ProgressBar Progress="{Binding CaloriesProgress}" HeightRequest="6" BackgroundColor="#E0E0E0" ProgressColor="#4CAF50" />
                    <Label Text="{Binding RemainingCalories, StringFormat='Осталось {0:F0} ккал'}" FontSize="12" TextColor="Gray" />

                    <!-- Белки -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Белки" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding TotalProteins, StringFormat='{0:F1} / {1:F1} г'}" FontSize="14" />
                    </Grid>
                    <ProgressBar Progress="{Binding ProteinsProgress}" HeightRequest="6" BackgroundColor="#E0E0E0" ProgressColor="#2196F3" />
                    <Label Text="{Binding RemainingProteins, StringFormat='Осталось {0:F1} г'}" FontSize="12" TextColor="Gray" />

                    <!-- Жиры -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Жиры" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding TotalFats, StringFormat='{0:F1} / {1:F1} г'}" FontSize="14" />
                    </Grid>
                    <ProgressBar Progress="{Binding FatsProgress}" HeightRequest="6" BackgroundColor="#E0E0E0" ProgressColor="#FF9800" />
                    <Label Text="{Binding RemainingFats, StringFormat='Осталось {0:F1} г'}" FontSize="12" TextColor="Gray" />

                    <!-- Углеводы -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Углеводы" FontSize="14" />
                        <Label Grid.Column="1" Text="{Binding TotalCarbs, StringFormat='{0:F1} / {1:F1} г'}" FontSize="14" />
                    </Grid>
                    <ProgressBar Progress="{Binding CarbsProgress}" HeightRequest="6" BackgroundColor="#E0E0E0" ProgressColor="#9C27B0" />
                    <Label Text="{Binding RemainingCarbs, StringFormat='Осталось {0:F1} г'}" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- Список продуктов выбранного типа (карточки) -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding CurrentItems}"
                        EmptyView="Нет записей в этом приёме"
                        Margin="0,10,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItem Text="Удалить"
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:DiaryViewModel}}, Path=DeleteMealItemCommand}"
                                       CommandParameter="{Binding .}" />
                        </SwipeView.RightItems>
                        <Frame Padding="10"
                               BackgroundColor="White"
                               CornerRadius="10"
                               HasShadow="True"
                               Margin="0,5">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                <!-- Название и граммы -->
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Product.Name}" FontAttributes="Bold" FontSize="16" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding QuantityGrams, StringFormat='{0} г'}" HorizontalOptions="End" FontSize="14" TextColor="Gray" />
                                <Label Grid.Row="0" Grid.Column="2" Text="{Binding Calories, StringFormat='{0:F0} ккал'}" FontSize="14" TextColor="#4CAF50" />

                                <!-- Макронутриенты -->
                                <Label Grid.Row="1" Grid.ColumnSpan="3" Margin="0,5,0,0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Б: " FontSize="12" TextColor="Gray" />
                                            <Span Text="{Binding Proteins, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#2196F3" />
                                            <Span Text="  Ж: " FontSize="12" TextColor="Gray" />
                                            <Span Text="{Binding Fats, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#FF9800" />
                                            <Span Text="  У: " FontSize="12" TextColor="Gray" />
                                            <Span Text="{Binding Carbs, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#9C27B0" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Панель добавления продукта -->
        <VerticalStackLayout Grid.Row="4" Spacing="10" Margin="0,10,0,0">
            <Label Text="Добавить продукт" FontAttributes="Bold" FontSize="16" />
            <Frame Padding="10" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Picker Title="Продукт"
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProductForAdd}"
                            BackgroundColor="#F5F5F5">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                    <Entry Placeholder="Масса (г)"
                           Text="{Binding QuantityGrams}"
                           Keyboard="Numeric"
                           BackgroundColor="#F5F5F5" />
                    <Button Text="Добавить в выбранный приём"
                            Command="{Binding AddMealItemCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="20"
                            HeightRequest="50" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>