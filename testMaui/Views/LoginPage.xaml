<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.LoginPage"
             Title="Вход">
    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <!-- ВОТ СЮДА ВСТАВЛЯЕТСЯ ПРЕДОСТАВЛЕННЫЙ КОД -->
    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry Placeholder="Имя пользователя" Text="{Binding UserName}" />
        <Entry Placeholder="Пароль" Text="{Binding Password}" IsPassword="True" />
        <Button Text="Войти" Command="{Binding LoginCommand}" />
        <Button Text="Создать новый аккаунт" Command="{Binding GoToRegisterCommand}" 
                BackgroundColor="Gray" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>