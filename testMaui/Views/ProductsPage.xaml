<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.ProductsPage"
             Title="Продукты"
             BackgroundColor="#F5F5F5">
    <ContentPage.BindingContext>
        <viewmodels:ProductsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto" RowSpacing="10" Padding="15">
        <!-- Список продуктов в виде карточек -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Products}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedProduct}"
                        EmptyView="Нет продуктов">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10"
                           BackgroundColor="White"
                           CornerRadius="10"
                           HasShadow="True"
                           Margin="0,5">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Calories, StringFormat='{0:F0} ккал/100г'}" FontSize="14" TextColor="#4CAF50" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5,0,0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Б: " FontSize="12" TextColor="Gray" />
                                        <Span Text="{Binding Proteins, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#2196F3" />
                                        <Span Text="  Ж: " FontSize="12" TextColor="Gray" />
                                        <Span Text="{Binding Fats, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#FF9800" />
                                        <Span Text="  У: " FontSize="12" TextColor="Gray" />
                                        <Span Text="{Binding Carbs, StringFormat='{0:F1}г'}" FontSize="12" TextColor="#9C27B0" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Панель добавления/редактирования -->
        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Label Text="Добавить / Редактировать продукт" FontAttributes="Bold" FontSize="16" />
            <Frame Padding="10" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Название" Text="{Binding NewProductName}" BackgroundColor="#F5F5F5" />
                    <Entry Placeholder="Калории (ккал)" Text="{Binding NewProductCalories}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <Entry Placeholder="Белки (г)" Text="{Binding NewProductProteins}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <Entry Placeholder="Жиры (г)" Text="{Binding NewProductFats}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <Entry Placeholder="Углеводы (г)" Text="{Binding NewProductCarbs}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Добавить" Command="{Binding AddProductCommand}"
                                BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20" HeightRequest="50" HorizontalOptions="FillAndExpand"/>
                        <Button Text="Обновить" Command="{Binding UpdateProductCommand}"
                                BackgroundColor="#2196F3" TextColor="White" CornerRadius="20" HeightRequest="50" HorizontalOptions="FillAndExpand"/>
                    </HorizontalStackLayout>

                    <Button Text="Удалить выбранный" Command="{Binding DeleteProductCommand}"
                            BackgroundColor="#F44336" TextColor="White" CornerRadius="20" HeightRequest="50"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>