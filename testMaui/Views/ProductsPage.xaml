<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             xmlns:local="clr-namespace:testMaui"
             x:Class="testMaui.Views.ProductsPage"
             Title="Продукты"
             BackgroundColor="#F5F5F5">
    <ContentPage.BindingContext>
        <viewmodels:ProductsViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <local:ProductToBackgroundMultiConverter x:Key="ProductToBackgroundMulti" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Padding="15">
        <!-- Заголовок -->
        <Label Grid.Row="0" Text="Список продуктов" FontAttributes="Bold" FontSize="18" Margin="0,0,0,5"/>

        <!-- CollectionView продуктов (без встроенного выделения) -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Products}"
                        Margin="0,5">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10"
                            StrokeThickness="0"
                            Margin="0,5"
                            StrokeShape="RoundRectangle 10">
                        <Border.BackgroundColor>
                            <MultiBinding Converter="{StaticResource ProductToBackgroundMulti}">
                                <Binding Path="." />
                                <Binding Path="SelectedProduct" Source="{RelativeSource AncestorType={x:Type viewmodels:ProductsViewModel}}" />
                            </MultiBinding>
                        </Border.BackgroundColor>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProductsViewModel}}, Path=SelectProductCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="{Binding Calories, StringFormat='{0:F0} ккал на 100 г'}" FontSize="14" TextColor="#4CAF50"/>
                            <Label Text="{Binding Proteins, StringFormat='Белки: {0:F1} г | Жиры: {1:F1} г | Углеводы: {2:F1} г'}" FontSize="13" TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Панель редактирования (без изменений) -->
        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Название" Text="{Binding NewProductName}" />
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                        <!-- Строка с подписями -->
                        <Label Text="Ккал" Grid.Row="0" Grid.Column="0" HorizontalOptions="Start" FontSize="14"/>
                        <Label Text="Белки" Grid.Row="0" Grid.Column="1" HorizontalOptions="Start" FontSize="14"/>
                        <Label Text="Жиры" Grid.Row="0" Grid.Column="2" HorizontalOptions="Start" FontSize="14"/>
                        <Label Text="Углеводы" Grid.Row="0" Grid.Column="3" HorizontalOptions="Start" FontSize="14"/>

                        <!-- Строка с полями ввода -->
                        <Entry Grid.Row="1" Grid.Column="0" Text="{Binding NewProductCalories}" Keyboard="Numeric" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding NewProductProteins}" Keyboard="Numeric" />
                        <Entry Grid.Row="1" Grid.Column="2" Text="{Binding NewProductFats}" Keyboard="Numeric" />
                        <Entry Grid.Row="1" Grid.Column="3" Text="{Binding NewProductCarbs}" Keyboard="Numeric" />
                    </Grid>
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Добавить"
                                Command="{Binding AddProductCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="50"
                                HorizontalOptions="FillAndExpand" />
                        <Button Text="Обновить"
                                Command="{Binding UpdateProductCommand}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="50"
                                HorizontalOptions="FillAndExpand" />
                        <Button Text="Удалить"
                                Command="{Binding DeleteProductCommand}"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="50"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>