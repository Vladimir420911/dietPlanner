<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:testMaui.ViewModels"
             x:Class="testMaui.Views.ProfilePage"
             Title="Профиль"
             BackgroundColor="#F5F5F5">
    <ContentPage.BindingContext>
        <viewmodels:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- Данные пользователя в карточке -->
            <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Имя"/>
                    <Entry Placeholder="Имя" Text="{Binding UserName}" BackgroundColor="#F5F5F5" />
                    <Label Text="Возраст"/>
                    <Entry Placeholder="Возраст" Text="{Binding Age}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <!-- Пол -->
                    <Picker Title="Пол"
        SelectedItem="{Binding Gender}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Мужской</x:String>
                                <x:String>Женский</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Label Text="Вес (кг)"/>
                    <Entry Placeholder="Вес (кг)" Text="{Binding Weight}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <Label Text="Рост (см)"/>
                    <Entry Placeholder="Рост (см)" Text="{Binding Height}" Keyboard="Numeric" BackgroundColor="#F5F5F5" />
                    <!-- Активность -->
                    <Picker Title="Активность"
        SelectedItem="{Binding ActivityLevel}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Низкая</x:String>
                                <x:String>Средняя</x:String>
                                <x:String>Высокая</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <!-- Цель -->
                    <Picker Title="Цель"
        SelectedItem="{Binding Goal}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Похудение</x:String>
                                <x:String>Поддержание</x:String>
                                <x:String>Набор массы</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Label Text="Пароль"/>
                    <Entry Placeholder="Пароль" Text="{Binding Password}" IsPassword="True" BackgroundColor="#F5F5F5" />
                </VerticalStackLayout>
            </Frame>

            <!-- Рассчитанные нормы в отдельной карточке с прогресс-барами (как на DiaryPage) -->
            <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ваши нормы" FontAttributes="Bold" FontSize="16" Margin="0,0,0,5"/>

                    <!-- Калории -->
                    <Label Text="{Binding DailyCalorieNorm, StringFormat='Калории: {0:F0} ккал'}" FontSize="14"/>

                    <!-- Белки -->
                    <Label Text="{Binding DailyProteinNorm, StringFormat='Белки: {0:F1} г'}" FontSize="14"/>

                    <!-- Жиры -->
                    <Label Text="{Binding DailyFatNorm, StringFormat='Жиры: {0:F1} г'}" FontSize="14"/>

                    <!-- Углеводы -->
                    <Label Text="{Binding DailyCarbNorm, StringFormat='Углеводы: {0:F1} г'}" FontSize="14"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Кнопки -->
            <Button Text="Сохранить профиль" Command="{Binding SaveProfileCommand}"
                    BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20" HeightRequest="50"/>
            <Button Text="Выйти" Command="{Binding LogoutCommand}"
                    BackgroundColor="#F44336" TextColor="White" CornerRadius="20" HeightRequest="50"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>